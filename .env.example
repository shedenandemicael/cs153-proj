# Database — Neon Postgres (local + Vercel production)
# Pooled connection (app runtime). Vercel/Neon integration sets this automatically.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
# Direct connection (migrations). From Neon dashboard: "Connection string" without -pooler.
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# LLM provider: mock | openai | workers-ai
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
# Vision model for photo → listing (gpt-4o recommended for best image understanding)
OPENAI_MODEL=gpt-4o-mini
# Dedicated model for price determination (vision + comparables)
OPENAI_PRICING_MODEL=gpt-4o
# openai | stats — stats skips OpenAI for pricing (comparable math only)
PRICING_PROVIDER=openai
WORKERS_AI_ACCOUNT_ID=
WORKERS_AI_API_TOKEN=

# eBay API — fetch-only market research (optional; mocks when unset)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENV=sandbox
# sandbox | production — sell/publish side
# Comps use production by default when EBAY_ENV=sandbox (sandbox has almost no listings)
EBAY_RESEARCH_ENV=production
# Fetch toggles (application token; no user OAuth required)
EBAY_FETCH_ACTIVE=true
EBAY_FETCH_SOLD=true
# Set false to fail instead of falling back to mock comparables
EBAY_ALLOW_MOCK_FALLBACK=true
# OAuth scope for client-credentials token (Browse + Taxonomy + Insights)
EBAY_OAUTH_SCOPES=https://api.ebay.com/oauth/api_scope

# Marketplace account deletion notifications (required for production keyset compliance)
# Generate a random 32–80 char token (letters, numbers, underscore, hyphen only)
EBAY_NOTIFICATION_VERIFICATION_TOKEN=
# Must exactly match the URL you register in eBay Developer Portal (HTTPS, no localhost)
EBAY_NOTIFICATION_ENDPOINT_URL=https://your-domain.com/api/ebay/notifications/account-deletion

# Autonomous agent policy
AGENT_AUTO_APPROVE=true
AGENT_CONFIDENCE_THRESHOLD=0.72
AGENT_AUTO_PUBLISH=false
AGENT_PUBLISH_CONFIDENCE_THRESHOLD=0.85
AGENT_BLOCKING_WARNINGS=authenticity,recall,counterfeit
AGENT_TIME_SAVED_MINUTES=18
BATCH_MAX_ITEMS=10
BATCH_MAX_PHOTOS=30
BATCH_SINGLE_MAX_IMAGES=10

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
UPLOAD_DIR=public/uploads
